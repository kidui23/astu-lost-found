# ==========================================
# 🛑 DO NOT COMMIT YOUR ACTUAL .env FILE 🛑
# ==========================================
# This is a template. Copy this file to `.env` and fill in your actual values.
# `cp .env.example .env`

# 1. API Configuration
PORT=5000

# 2. Database Connection
# Keep this format but replace credentials and cluster info for MongoDB Atlas
# E.g. mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/lostfound
MONGODB_URI=mongodb://127.0.0.1:27017/lostfound

# 3. Security & Authentication
# Generate a secure string (e.g. using `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
JWT_SECRET=replace_this_with_a_long_secure_random_string_in_production
